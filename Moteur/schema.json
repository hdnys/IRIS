{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "IRIS Data Pool",
    "description": "Shared context updated by each model in the pipeline. Static fields control orchestration; dynamic fields carry model outputs.",
    "type": "object",
    "properties": {
        "static": {
            "type": "object",
            "description": "Set by the VLM after processing a frame. Used by the orchestrator to decide which downstream models to invoke.",
            "properties": {
                "frame_id": {
                    "type": "string",
                    "description": "Unique identifier for the current frame being processed."
                },
                "timestamp": {
                    "type": "number",
                    "description": "Unix timestamp (ms) when the frame was captured."
                },
                "is_new_scene": {
                    "type": "boolean",
                    "description": "True if the VLM determined this frame represents a sufficiently new scene, triggering a full context reset."
                },
                "scene_type": {
                    "type": "string",
                    "enum": ["indoor", "outdoor", "vehicle", "unknown"],
                    "description": "Broad scene category inferred by the VLM."
                },
                "lighting_condition": {
                    "type": "string",
                    "enum": ["bright", "normal", "dim", "dark", "unknown"],
                    "description": "Estimated lighting level in the frame."
                },
                "motion_level": {
                    "type": "string",
                    "enum": ["still", "slow", "fast", "unknown"],
                    "description": "Estimated level of motion in the scene."
                },
                "run_object_detection": {
                    "type": "boolean",
                    "description": "Orchestrator flag: invoke the object detection and categorization model."
                },
                "run_face_recognition": {
                    "type": "boolean",
                    "description": "Orchestrator flag: invoke the facial recognition model. Should only be true when people are present."
                },
                "run_emotion_detection": {
                    "type": "boolean",
                    "description": "Orchestrator flag: invoke the emotion detection model. Should only be true when faces are detected."
                },
                "run_ocr": {
                    "type": "boolean",
                    "description": "Orchestrator flag: invoke the OCR model when text is visible in the scene."
                },
                "run_depth_estimation": {
                    "type": "boolean",
                    "description": "Orchestrator flag: invoke the depth/distance estimation model."
                },
                "people_present": {
                    "type": "boolean",
                    "description": "Whether one or more people are visible in the frame."
                },
                "people_count": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Estimated number of people in the frame."
                },
                "text_visible": {
                    "type": "boolean",
                    "description": "Whether readable text is present in the scene (signs, labels, screens, etc.)."
                },
                "hazard_detected": {
                    "type": "boolean",
                    "description": "Whether the VLM flagged a potential navigation hazard (steps, obstacle, traffic, etc.)."
                },
                "priority_context": {
                    "type": "string",
                    "enum": ["navigation", "social", "reading", "general"],
                    "description": "VLM's assessment of the most relevant context mode for the user's current situation."
                }
            },
            "required": [
                "frame_id",
                "timestamp",
                "is_new_scene",
                "scene_type",
                "run_object_detection",
                "run_face_recognition",
                "run_emotion_detection",
                "run_ocr",
                "run_depth_estimation",
                "people_present",
                "text_visible",
                "hazard_detected",
                "priority_context"
            ]
        },
        "dynamic": {
            "type": "object",
            "description": "Populated by downstream models after the orchestrator dispatches them. Structure varies per model.",
            "properties": {
                "objects": {
                    "type": "array",
                    "description": "Output from the object detection model.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "label": { "type": "string" },
                            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                            "bounding_box": {
                                "type": "object",
                                "properties": {
                                    "x": { "type": "number" },
                                    "y": { "type": "number" },
                                    "width": { "type": "number" },
                                    "height": { "type": "number" }
                                }
                            },
                            "distance_m": { "type": ["number", "null"], "description": "Estimated distance in meters from depth model, null if not run." }
                        },
                        "required": ["label", "confidence"]
                    }
                },
                "faces": {
                    "type": "array",
                    "description": "Output from the facial recognition model.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "person_id": { "type": ["string", "null"], "description": "Known identity, null if unrecognized." },
                            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                            "emotion": { "type": ["string", "null"], "description": "Detected emotion from emotion model, null if not run." },
                            "bounding_box": {
                                "type": "object",
                                "properties": {
                                    "x": { "type": "number" },
                                    "y": { "type": "number" },
                                    "width": { "type": "number" },
                                    "height": { "type": "number" }
                                }
                            }
                        },
                        "required": ["person_id", "confidence"]
                    }
                },
                "text_blocks": {
                    "type": "array",
                    "description": "Output from the OCR model.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "text": { "type": "string" },
                            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
                        },
                        "required": ["text", "confidence"]
                    }
                },
                "vlm_description": {
                    "type": ["string", "null"],
                    "description": "Final natural language description generated by the VLM acting as LLM, tailored to the user's vision profile."
                }
            }
        },
        "user_profile": {
            "type": "object",
            "description": "Persistent user configuration. Loaded once at session start, not modified by models.",
            "properties": {
                "vision_profile": {
                    "type": "string",
                    "enum": ["total_blindness", "low_vision", "tunnel_vision", "color_blindness", "peripheral_loss"],
                    "description": "The user's vision condition, used to tailor VLM output verbosity and focus."
                },
                "preferred_language": {
                    "type": "string",
                    "description": "BCP-47 language tag for TTS output (e.g. 'en-US', 'fr-FR')."
                },
                "verbosity": {
                    "type": "string",
                    "enum": ["minimal", "standard", "detailed"],
                    "description": "How much detail the VLM should include in descriptions."
                },
                "known_people": {
                    "type": "array",
                    "description": "Registry of recognized individuals for facial recognition.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "string" },
                            "name": { "type": "string" },
                            "relationship": { "type": "string" }
                        },
                        "required": ["id", "name"]
                    }
                }
            },
            "required": ["vision_profile", "preferred_language", "verbosity"]
        }
    },
    "required": ["static", "dynamic", "user_profile"]
}
